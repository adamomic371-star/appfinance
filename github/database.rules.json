{
  "rules": {
    "users": {
      ".read": true,
      ".write": true,
      "$uid": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['email', 'password', 'name'])"
      }
    },
    "groups": {
      ".read": true,
      ".write": true,
      "$gid": {
        ".read": true,
        ".write": true
      }
    },
    "admin_logs": {
      ".read": true,
      ".write": true
    },
    "admin_settings": {
      ".read": true,
      ".write": true
    },
    "config": {
      ".read": true,
      ".write": true
    }
  }
}
