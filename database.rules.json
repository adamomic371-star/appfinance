{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "$uid === auth.uid"
      }
    },
    "groups": {
      ".read": "auth != null",
      "$gid": {
        ".write": "auth != null && (data.child('members').child(auth.uid).exists() || !data.exists())"
      }
    },
    "admin_logs": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "admin_settings": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
