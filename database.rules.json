{
  "rules": {
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "groups": {
      ".read": false,
      ".write": false,
      "$gid": {
        ".read": "auth != null && (data.child('members').child(auth.uid).exists() || root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin')",
        ".write": "auth != null && (data.child('members').child(auth.uid).exists() || !data.exists())"
      }
    },
    "sharedGoals": {
      ".read": false,
      ".write": false,
      "$sgid": {
        ".read": "auth != null && (data.child('members').child(auth.uid).exists() || data.child('ownerId').val() === auth.uid)",
        ".write": "auth != null && (data.child('ownerId').val() === auth.uid || !data.exists())"
      }
    },
    "admin_logs": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin'"
    },
    "admin_settings": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin'"
    },
    "config": {
      ".read": "auth != null",
      "plans": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin'"
      },
      "featureFlags": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin'"
      },
      "$other": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin'",
        ".write": "auth != null && root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin'"
      }
    }
  }
}
