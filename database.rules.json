{
  "rules": {
    "users": {
      ".read": true,
      "$uid": {
        ".write": "auth != null && $uid === auth.uid"
      }
    },
    "groups": {
      ".read": true,
      "$gid": {
        ".write": "auth != null"
      }
    },
    "admin_logs": {
      ".read": true,
      ".write": true
    },
    "admin_settings": {
      ".read": true,
      ".write": true
    }
  }
}