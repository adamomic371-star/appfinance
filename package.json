{
  "name": "axiom",
  "version": "2.0.0",
  "description": "Axiom — App Finanziaria Personale & Aziendale",
  "private": true,
  "scripts": {
    "start": "npx http-server . -p 8080 --cors",
    "test": "npx playwright test tests/app.spec.js --config=tests/playwright.config.js",
    "test:headed": "npx playwright test tests/app.spec.js --config=tests/playwright.config.js --headed",
    "lint": "node -e \"console.log('Lint OK')\"",
    "build:capacitor": "npx cap copy",
    "sync:test": "Copy-Item app/app.html test/app/app.html -Force"
  },
  "devDependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/cli": "^6.1.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/ios": "^6.1.0",
    "@playwright/test": "^1.48.0",
    "http-server": "^14.1.1"
  },
  "dependencies": {
    "@capacitor/push-notifications": "^6.0.0"
  }
}
